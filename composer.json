{
    "name": "api/xijie",
    "type": "project",
    "description": "The xijie api.",
    "keywords": [
        "framework",
        "laravel",
        "xijie"
    ],
    "license": "MIT",
    "require": {
        "php": "7.4.*|^8.0",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "ext-redis": "*",
        "ext-simplexml": "*",
        "ext-sockets": "*",
        "ext-xml": "*",
        "alibabacloud/facebody-20191230": "*",
        "alibabacloud/sdk": "^1.8",
        "alipaysdk/easysdk": "^2.2",
        "alipaysdk/openapi": "^3.0",
        "apsg/fpdi-fpdf": "^2.3",
        "codeitnowin/barcode": "dev-master",
        "doctrine/dbal": "^3.1",
        "eleme-openapi-php-sdk/eleme-openapi-php-sdk": "^1.92.0",
        "endroid/qr-code": "^4.4",
        "fideloper/proxy": "^4.4",
        "fruitcake/laravel-cors": "^2.0",
        "godruoyi/php-snowflake": "^1.1",
        "guanguans/laravel-exception-notify": "^2.12",
        "guzzlehttp/guzzle": "^7.3",
        "intervention/image": "^2.7",
        "xijie-composer/api-time": "1.1.1",
        "xijie/csv-stream-exporter": "1.0.3",
        "xijie/file": "^1.3",
        "xijie/general-fs": "^1.0",
        "xijie/green-content": "^1.0",
        "xijie/ipwhite": "^1.0",
        "xijie/laravel-clickhouse": "1.9",
        "xijie/nsq": "^2.0",
        "xijie/recognizer": "^1.3",
        "laravel/framework": "^8.40",
        "laravel/tinker": "^2.5",
        "league/csv": "^9.8",
        "league/flysystem-cached-adapter": "^1.0",
        "league/flysystem-sftp": "^1.0",
        "maatwebsite/excel": "^3.1",
        "phpoffice/phpspreadsheet": "^1.18",
        "predis/predis": "^1.1",
        "ritaswc/laravel-query-logger": "^2.1",
        "ritaswc/lark-card-message-builder": "1.0.2",
        "robrichards/xmlseclibs": "^3.1",
        "sensorsdata/sa-sdk-php": "^1.10",
        "stomp-php/stomp-php": "5.0.0",
        "tymon/jwt-auth": "^1.0",
        "wechatpay/wechatpay": "^1.1",
        "xingwenge/canal_php": "^1.0",
        "zedisdog/laravel-schema-extend": "^1.4"
    },
    "require-dev": {
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^5.0",
        "phpunit/phpunit": "^9.3.3",
        "squizlabs/php_codesniffer": "3.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan composer:install",
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "lint": "./vendor/bin/phpcs app/ --standard=PSR1,PSR2,PSR12,./ruleset.xml",
        "lint-fix": "./vendor/bin/phpcbf app/ --standard=PSR1,PSR2,PSR12,./ruleset.xml"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        },
        "platform": {
            "ext-pcntl": "7.2",
            "ext-posix": "7.2"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": {
        "packagist": {
            "type": "composer",
            "url": "https://mirrors.aliyun.com/composer/"
        },
        "xijie-composer/api-time": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/api-time.git"
        },
        "xijie/file": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/file.git"
        },
        "xin/container": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/xin-container.git"
        },
        "xin/helper": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/xin-helper.git"
        },
        "xijie/csv-stream-exporter": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/csv-stream-exporter.git"
        },
        "eleme-openapi-php-sdk/eleme-openapi-php-sdk": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/eleme-openapi-php-sdk.git"
        },
        "xijie/ipwhite": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/ipwhite.git"
        },
        "xijie/laravel-clickhouse": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/laravel-clickhouse.git"
        },
        "xijie/nsq": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/nsq.git"
        },
        "xijie/general-fs": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/general-fs.git"
        },
        "xijie/recognizer": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/recognizer.git"
        },
        "xijie/green-content": {
            "type": "vcs",
            "url": "https://git.xijie.com/package/green-content.git"
        }
    }
}
